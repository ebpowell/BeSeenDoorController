          <h2>\n                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">\n                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>\n                        </svg>\n                        Role Access Control\n                    </h2>\n                    <form action="/role/assign" method="POST" style="margin-bottom: 1.5rem;">\n                        <div class="form-group">\n                            <label for="assign_role_name">Select User Role</label>\n                            <select id="assign_role_name" name="role" required>\n                                <option value="" disabled selected>Select Role...</option>\n                                <option value="operator">operator</option>\n                                <option value="manager">manager</option>\n                                <option value="staff">staff</option>\n                            </select>\n                        </div>\n                        <div class="form-group">\n                            <label for="assign_role_property_id">Select Property Address</label>\n                            <select id="assign_role_property_id" name="property_id" required>\n                                <option value="" disabled selected>Select Address to Assign...</option>\n                                \n                                    <option value="10001">\n                                        101 Main St\n                                    </option>\n                                \n                            </select>\n                        </div>\n                        <button type="submit" class="btn btn-primary">Grant Role Access</button>\n                    </form>\n\n                    <h3 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--text-secondary);">Active Role Mappings</h3>\n                    <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">\n                        <table>\n                            <thead>\n                                <tr>\n                                    <th>Role</th>\n                                    <th>Address</th>\n                                    <th style="text-align: right;">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                \n                                    \n                                        <tr>\n                                            <td><span class="user-role"></span></td>\n                                            <td><span class="address-badge">101 Main St</span></td>\n                                            <td style="text-align: right;">\n                                                <form action="/role/unassign" method="POST" style="display:inline;">\n                                                    <input type="hidden" name="role" value="">\n                                                    <input type="hidden" name="property_id" value="10001">\n                                                    <button type="submit" class="btn btn-danger-outline" style="padding: 0.2rem 0.5rem; font-size: 0.75rem;">Revoke</button>\n                                                </form>\n                                            </td>\n                                        </tr>\n                                    \n                                \n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n                \n\n                <!-- Fixed Fact Table Properties Card -->\n                <div class="glass-card">\n                    <h2>\n                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">\n                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>\n                        </svg>\n                        Neighborhood\n                        <span class="badge-read-only">Properties Fact Table</span>\n                    </h2>\n                    <div class="table-responsive">\n                        <table>\n                            <thead>\n                                <tr>\n                                    <th>Address</th>\n                                    <th>Current Owner</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                \n                                    <tr>\n                                        <td><span class="address-badge">101 Main St</span></td>\n                                        <td><span class="owner-name">John Doe</span></td>\n                                    </tr>\n                                \n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Right Panel: Database Fobs List & Logs -->\n            <div class="list-panel">\n                <!-- Key Fobs Registry -->\n                <div class="glass-card">\n                    <h2>\n                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">\n                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>\n                        </svg>\n                        Key Fobs Registry\n                    </h2>\n                    \n                    <div class="search-container">\n                        <svg class="search-icon" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">\n                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>\n                        </svg>\n                        <input type="text" class="search-input" id="searchBox" placeholder="Search by Fob ID, Address, or Owner..." onkeyup="filterFobs()">\n                    </div>\n\n                    <div class="table-responsive">\n                        <table id="fobTable">\n                            <thead>\n                                <tr>\n                                    <th>Fob ID</th>\n                                    <th>Assigned Address</th>\n                                    <th>Inherited Owner</th>\n                                    <th style="text-align: right;">Actions</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                \n                                    \n                                        <tr>\n                                            <td><span class="fob-id-badge">1001</span></td>\n                                            <td><span class="address-badge">101 Main St</span></td>\n                                            <td><span class="owner-name">John Doe</span></td>\n                                            <td style="text-align: right;">\n                                                <form action="/fob/remove/1001" method="POST" style="display:inline;" onsubmit="return confirm(\'Are you sure you want to delete fob 1001?\');">\n                                                    <button type="submit" class="btn btn-danger-outline">Delete</button>\n                                                </form>\n                                            </td>\n                                        </tr>\n                                    \n                                \n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n\n                <!-- Fob Replacement Logs (Metadata History) Card -->\n                <div class="glass-card">\n                    <h2>\n                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">\n                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>\n                        </svg>\n                        Fob Replacement Logs (Metadata History)\n                    </h2>\n                    <div class="table-responsive">\n                        <table>\n                            <thead>\n                                <tr>\n                                    <th>Log ID</th>\n                                    <th>Property Address</th>\n                                    <th>Replaced Fob ID</th>\n                                    <th>New Fob ID</th>\n                                    <th>Timestamp</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                \n                                    <tr>\n                                        <td colspan="5" class="no-data">No replacement logs recorded.</td>\n                                    </tr>\n                                \n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n\n                <!-- User Audit Logs Card -->\n                <div class="glass-card">\n                    <h2>\n                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">\n                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>\n                        </svg>\n                        User Action Audit Logs\n                    </h2>\n                    <div class="table-responsive">\n                        <table>\n                            <thead>\n                                <tr>\n                                    <th>User</th>\n                                    <th>Action</th>\n                                    <th>Details</th>\n                                    <th>Timestamp</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                \n                                    <tr>\n                                        <td colspan="4" class="no-data">No action history recorded yet.</td>\n                                    </tr>\n                                \n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </div>\n\n    <!-- Replacement Modal -->\n    <div id="replacementModalBackdrop" class="modal-backdrop">\n        <div class="modal-content">\n            <button class="modal-close" onclick="closeModal()">&times;</button>\n            <div id="modalTitle" class="modal-title">Fob Replacement Prompt</div>\n            <div id="modalMessage" class="modal-body">\n                This address already has registered fobs. Select which fob will be replaced:\n            </div>\n            <div id="modalOptions" class="modal-options">\n                <!-- Javascript will render options here -->\n            </div>\n        </div>\n    </div>\n\n    <!-- Toast Notifications Container -->\n    <div class="toast-container">\n        \n            \n        \n    </div>\n\n    <!-- UI Scripts -->\n    <script>\n        // Inline raw JS data object of current fobs\n        const fobsData = [\n            \n            { fob_id: 1001, property_id: 10001, address: "101 Main St" },\n            \n        ];\n\n        // Automatic fade out for toast messages\n        document.addEventListener(\'DOMContentLoaded\', () => {\n            const toasts = document.querySelectorAll(\'.toast\');\n            toasts.forEach(toast => {\n                setTimeout(() => {\n                    toast.style.opacity = \'0\';\n                    toast.style.transform = \'translateX(100px)\';\n                    setTimeout(() => toast.remove(), 300);\n                }, 4000);\n            });\n        });\n\n        // Intercept Fob Assignment form submission\n        function handleAssignSubmit(event) {\n            const propertySelect = document.getElementById(\'add_property_id\');\n            const selectedPropId = parseInt(propertySelect.value);\n            const fobInput = document.getElementById(\'add_fob_id\');\n            const newFobId = parseInt(fobInput.value);\n\n            if (isNaN(selectedPropId) || isNaN(newFobId)) {\n                return true; // Let standard validation handle it\n            }\n\n            // Get fobs currently assigned to this property\n            const matchingFobs = fobsData.filter(f => f.property_id === selectedPropId);\n\n            if (matchingFobs.length > 0) {\n                // Intercept the form submission to open the replacement prompt\n                event.preventDefault();\n                showReplacementModal(selectedPropId, newFobId, matchingFobs);\n                return false;\n            }\n            return true;\n        }\n\n        // Open replacement modal\n        function showReplacementModal(propertyId, newFobId, matchingFobs) {\n            const backdrop = document.getElementById(\'replacementModalBackdrop\');\n            const title = document.getElementById(\'modalTitle\');\n            const message = document.getElementById(\'modalMessage\');\n            const optionsContainer = document.getElementById(\'modalOptions\');\n            \n            // Clear options\n            optionsContainer.innerHTML = \'\';\n            \n            title.textContent = `Assigning Fob ${newFobId}`;\n            \n            // If address has reached maximum of 2 fobs, force replacement\n            if (matchingFobs.length >= 2) {\n                message.textContent = `This address has reached the maximum of 2 fobs. Choose which existing fob to replace (the chosen fob will be deleted):`;\n            } else {\n                message.textContent = `This address has 1 existing fob. You can choose to replace it or add this new fob directly:`;\n                \n                // Add "Add directly without replacing" option\n                const directBtn = document.createElement(\'button\');\n                directBtn.type = \'button\';\n                directBtn.className = \'modal-option-btn\';\n                directBtn.style.borderLeft = "4px solid var(--success)";\n                directBtn.innerHTML = `<span>Add directly (No replacement)</span> <strong style="color:var(--success);">&rarr;</strong>`;\n                directBtn.onclick = () => {\n                    document.getElementById(\'replaced_fob_id\').value = \'\';\n                    document.getElementById(\'assignFobForm\').submit();\n                };\n                optionsContainer.appendChild(directBtn);\n            }\n            \n            // Add options for replacing each existing fob ID\n            matchingFobs.forEach(fob => {\n                const btn = document.createElement(\'button\');\n                btn.type = \'button\';\n                btn.className = \'modal-option-btn\';\n                btn.style.borderLeft = "4px solid var(--danger)";\n                btn.innerHTML = `<span>Replace Fob <strong style="color:var(--secondary); font-family:monospace;">${fob.fob_id}</strong></span> <strong style="color:var(--danger);">&times;</strong>`;\n                btn.onclick = () => {\n                    document.getElementById(\'replaced_fob_id\').value = fob.fob_id;\n                    document.getElementById(\'assignFobForm\').submit();\n                };\n                optionsContainer.appendChild(btn);\n            });\n            \n            backdrop.classList.add(\'show\');\n        }\n\n        // Close modal\n        function closeModal() {\n            document.getElementById(\'replacementModalBackdrop\').classList.remove(\'show\');\n        }\n\n        // Search Filter Logic\n        function filterFobs() {\n            const searchInput = document.getElementById(\'searchBox\').value.toLowerCase();\n            const table = document.getElementById(\'fobTable\');\n            const trs = table.getElementsByTagName(\'tbody\')[0].getElementsByTagName(\'tr\');\n            \n            for (let i = 0; i < trs.length; i++) {\n                const tr = trs[i];\n                if (tr.getElementsByClassName(\'no-data\').length > 0) continue;\n                \n                const fobBadge = tr.getElementsByClassName(\'fob-id-badge\')[0];\n                const addressBadge = tr.getElementsByClassName(\'address-badge\')[0];\n                const ownerName = tr.getElementsByClassName(\'owner-name\')[0];\n                \n                const fobIdText = fobBadge ? fobBadge.textContent || fobBadge.innerText : \'\';\n                const addressText = addressBadge ? addressBadge.textContent || addressBadge.innerText : \'\';\n                const ownerText = ownerName ? ownerName.textContent || ownerName.innerText : \'\';\n                \n                if (fobIdText.toLowerCase().indexOf(searchInput) > -1 || \n                    addressText.toLowerCase().indexOf(searchInput) > -1 ||\n                    ownerText.toLowerCase().indexOf(searchInput) > -1) {\n                    tr.style.display = "";\n                } else {\n                    tr.style.display = "none";\n                }\n            }\n        }\n    </script>\n</body>\n</html>'

